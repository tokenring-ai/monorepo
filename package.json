{
  "name": "@tokenring-ai/monorepo",
  "version": "0.2.44",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.2"
  },
  "description": "TokenRing Monorepo with all community apps and packages",
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit",
    "build-docs": "cd docs && bun run build",
    "coder": "bun --env app/coder/src/tr-coder.js",
    "writer": "bun --env app/writer/src/tr-writer.js",
    "test": "bun run test",
    "prepare": "husky",
    "update-all-dependencies-latest": "bun update --latest",
    "biome": "biome check --fix",
    "lint": "oxlint -f stylish --fix"
  },
  "type": "module",
  "overrides": {
    "uuid": "14.0.0",
    "qs": "^6.14.1",
    "dompurify": "^3.3.2",
    "@xmldom/xmldom": "^0.8.13",
    "follow-redirects": "^1.16.0",
    "form-data": "^2.5.4",
    "axios": "^1.15.0",
    "esbuild": "^0.25.0",
    "hono": "^4.12.14",
    "tough-cookie": "^4.1.3",
    "postcss": "^8.5.10",
    "fast-xml-parser": "^5.7.0",
    "request": "npm:@cypress/request@^3.0.10",
    "basic-ftp": "^5.2.2"
  },
  "workspaces": {
    "packages": [
      "pkg/*",
      "app/*",
      "frontend/*",
      "deps/*"
    ]
  }
}
