{
  "name": "@tokenring-ai/monorepo",
  "version": "0.2.49",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tokenring-ai/ai-client": "workspace:*",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "description": "TokenRing Monorepo with all community apps and packages",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "docs:build": "cd docs && bun run build",
    "deps:update": "bun update --latest",
    "deps:build": "cd deps/naudiodon3 && bun run install",
    "package:one:frontend": "bun run --cwd packaging/npm/one stage:frontend",
    "package:one:docker": "bun run --cwd packaging/docker/one build",
    "check:biome": "biome check --fix",
    "check:oxlint": "oxlint -f stylish --fix",
    "check:knip": "knip",
    "check:tsc": "tsc",
    "check:tsc-tests": "tsc --noEmit -p tsconfig.tests.json"
  },
  "type": "module",
  "overrides": {
    "uuid": "14.0.0",
    "qs": "^6.14.1",
    "dompurify": "^3.3.2",
    "@xmldom/xmldom": "^0.8.13",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.5",
    "axios": "^1.15.0",
    "esbuild": "^0.28.0",
    "ip-address": ">10.1.0",
    "hono": ">=4.12.18",
    "exiftool-vendored": ">35.18.0",
    "fast-uri": ">3.1.1",
    "fast-xml-builder": ">1.1.6",
    "tough-cookie": "^6.0.0",
    "postcss": "^8.5.10",
    "fast-xml-parser": "^5.7.0",
    "request": "npm:@cypress/request@^3.0.10",
    "basic-ftp": "^5.2.2"
  },
  "workspaces": {
    "packages": [
      "pkg/*",
      "app/*",
      "frontend/*",
      "deps/*"
    ]
  }
}
