{
  "name": "@tokenring-ai/monorepo",
  "description": "TokenRing Monorepo with all community apps and packages",
  "version": "0.2.40",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bun-types": "^1.3.11",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit",
    "coder": "bun --env app/coder/src/tr-coder.js",
    "writer": "bun --env app/writer/src/tr-writer.js",
    "test": "bun run test",
    "prepare": "husky",
    "update-all-dependencies-latest": "bun update --latest"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "pkg/*",
      "app/*",
      "frontend/*",
      "deps/*",
      "docs"
    ]
  },
  "dependencies": {
    "@types/mime-types": "^3.0.1",
    "glob": "^13.0.6",
    "mime-types": "^3.0.2",
    "naudiodon2": "^2.5.0"
  }
}
