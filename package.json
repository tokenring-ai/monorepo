{
  "name": "@tokenring-ai/monorepo",
  "version": "0.2.42",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.2"
  },
  "description": "TokenRing Monorepo with all community apps and packages",
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit",
    "build-docs": "cd docs && bun run build",
    "coder": "bun --env app/coder/src/tr-coder.js",
    "writer": "bun --env app/writer/src/tr-writer.js",
    "test": "bun run test",
    "prepare": "husky",
    "update-all-dependencies-latest": "bun update --latest"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "pkg/*",
      "app/*",
      "frontend/*",
      "deps/*",
      "docs"
    ]
  }
}
